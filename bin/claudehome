#!/usr/bin/env bash
# claudehome — connect to a persistent Claude Code session on your Mac mini.
# See README.md for architecture and acceptance criteria.

set -euo pipefail

# warn <message...> — print prefixed warning to stderr, return 0.
# Defined early so all helpers can use it. Always succeeds; safe under set -e.
warn() { echo "claudehome: $*" >&2; return 0; }

# ---- help ----
if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  cat <<'USAGE'
Usage: claudehome

  Lists project directories under CLAUDEHOME_PROJECTS_DIR on the Mac mini,
  shows tmux session state for each, and attaches via SSH over Tailscale.
  Sessions are named claudehome-<project> and outlive any claude process.

  When run on the Mac mini itself (auto-detected by hostname, or forced
  with CLAUDEHOME_LOCAL=1), the SSH layer is skipped and the picker plus
  attach run locally — useful when SSH'd into the mini from iPhone, etc.

  5-type structure: Folders organize, Suites group masterplan workspaces
  (*_suite), Projects/Hubs/Members are attachable. The last picker row is
  [new...] — pick a type and a name. Suite-with-Hub Members get hub-aware
  scaffolding (git init + @-import + projects.md row). Project/Hub/Member
  names are globally unique across the whole tree; tmux sessions are named
  claudehome-<basename> regardless of depth.

Environment variables (or set in ~/.claudehomerc):
  CLAUDEHOME_HOST          Tailscale hostname of the Mac mini   (required)
  CLAUDEHOME_USER          SSH user on the Mac mini             (default: $USER)
  CLAUDEHOME_PROJECTS_DIR  Projects root on the Mac mini        (default: ~/projects/claudehome-projects)
  CLAUDEHOME_LOCAL         Force local mode (1) or remote (0)   (default: auto-detect)

Config file: ~/.claudehomerc — written by install_client.sh. Format: KEY=VALUE, one per line.
Environment variables take precedence over values in the config file.

Detach from an attached session with tmux's standard binding:
  Ctrl-b then d  (two keystrokes: hold Ctrl+b, release, then press d)
The tmux session keeps running on the Mac mini after you disconnect.

Note: CLAUDEHOME_PROJECTS_DIR is a path on the Mac mini. If you use a
leading ~, set it with single quotes so your client shell does not
expand the tilde locally: export CLAUDEHOME_PROJECTS_DIR='~/other/root'
USAGE
  exit 0
fi

# ---- load config file (env vars take precedence) ----
RC="${HOME}/.claudehomerc"
if [[ -f "$RC" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^(CLAUDEHOME_[A-Z_]+)=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      val="${BASH_REMATCH[2]}"
      if ! printenv "$key" >/dev/null 2>&1; then
        export "$key"="$val"
      fi
    fi
  done < "$RC"
fi

# ---- config ----
HOST="${CLAUDEHOME_HOST:-}"
REMOTE_USER="${CLAUDEHOME_USER:-$USER}"
PROJECTS_DIR="${CLAUDEHOME_PROJECTS_DIR:-~/projects/claudehome-projects}"

if [[ -z "$HOST" ]]; then
  echo "claudehome: CLAUDEHOME_HOST is not set." >&2
  echo "  Run ./install_client.sh to configure, or: export CLAUDEHOME_HOST=<tailscale-hostname>" >&2
  exit 1
fi

# ---- validate config ----
# These values are interpolated into a remote `bash -c '...'` command. Strict
# allowlists close the shell-injection vector (a single quote in any of these
# would break out of the remote bash -c context).
if [[ ! "$HOST" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_HOST='${HOST}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '-'" >&2
  exit 1
fi
if [[ ! "$REMOTE_USER" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_USER='${REMOTE_USER}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '-'" >&2
  exit 1
fi
if [[ ! "$PROJECTS_DIR" =~ ^[a-zA-Z0-9._~/-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_PROJECTS_DIR='${PROJECTS_DIR}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '/', '~', '-'" >&2
  exit 1
fi

# ---- detect local execution ----
# When CLAUDEHOME_HOST resolves to this machine, skip the SSH hop and run the
# picker + attach locally. Common case: SSH'd into the mini from an iPhone
# (Termius/Blink) — we want the same picker UX, no loopback SSH.
#
# Detection layers:
#   1. CLAUDEHOME_LOCAL=1|true|yes  → force local
#   2. CLAUDEHOME_LOCAL=0|false|no  → force remote (loopback test path)
#   3. Cheap string match: localhost / 127.* / ::1 / hostname forms.
#   4. IP-based match: resolve HOST and compare to local interface IPs. This
#      catches every macOS hostname variant (LocalHostName vs HostName vs
#      Tailscale node name) — they all resolve to the same IPs the box owns.
_resolve_ips() {
  local h=$1
  if command -v dscacheutil >/dev/null 2>&1; then
    dscacheutil -q host -a name "$h" 2>/dev/null \
      | awk '/^ip[46]?_address:/ {print $2}'
  elif command -v getent >/dev/null 2>&1; then
    getent ahosts "$h" 2>/dev/null | awk '{print $1}' | sort -u
  elif command -v host >/dev/null 2>&1; then
    host "$h" 2>/dev/null | awk '/has address|has IPv6 address/ {print $NF}'
  fi
}
_local_ips() {
  if command -v ifconfig >/dev/null 2>&1; then
    ifconfig 2>/dev/null | awk '/^[[:space:]]*inet6? / {print $2}' | sed 's/%.*//'
  elif command -v ip >/dev/null 2>&1; then
    ip -o addr show 2>/dev/null | awk '{print $4}' | sed 's|/.*||'
  fi
}
is_local_target() {
  case "${CLAUDEHOME_LOCAL:-}" in
    1|true|yes) return 0 ;;
    0|false|no) return 1 ;;
  esac
  local target=$1 lc_target lc_full lc_short
  case "$target" in
    localhost|127.*|::1) return 0 ;;
  esac
  lc_target=$(printf '%s' "$target" | tr '[:upper:]' '[:lower:]')
  lc_full=$(hostname 2>/dev/null  | tr '[:upper:]' '[:lower:]')
  lc_short=$(hostname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')
  [[ -n "$lc_full"  && "$lc_target" == "$lc_full"  ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "$lc_short" ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "${lc_short}.local" ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "${lc_short}".*.ts.net ]] && return 0
  # Final layer: IP intersection between resolved-target and local interfaces.
  local target_ips local_ips tip lip
  target_ips=$(_resolve_ips "$target")
  [[ -z "$target_ips" ]] && return 1
  local_ips=$(_local_ips)
  [[ -z "$local_ips" ]] && return 1
  for tip in $target_ips; do
    for lip in $local_ips; do
      [[ "$tip" == "$lip" ]] && return 0
    done
  done
  return 1
}
LOCAL_MODE=0
is_local_target "$HOST" && LOCAL_MODE=1

# Local mode passes paths to local commands directly, so we expand a leading
# `~/` to $HOME up front. Remote mode leaves PROJECTS_DIR literal — the
# remote bash -c context expands `~` itself.
LOCAL_DIR="$PROJECTS_DIR"
# shellcheck disable=SC2088 # The '~' here is a literal pattern in `case`, not a tilde to expand.
case "$PROJECTS_DIR" in
  '~')   LOCAL_DIR="$HOME" ;;
  '~/'*) LOCAL_DIR="${HOME}/${PROJECTS_DIR#\~/}" ;;
esac

# ---- tree-walk emitter (shared between local and remote modes) ----
# Emits "<path>\t<type>\t<child_count>\n" rows for every directory under the
# projects root, plus optional ---TRUNCATED--- / ---DEPTH-TRUNCATED--- sentinels.
# Type is R (synthetic root, only the `.` row), F (folder — every immediate
# child is a directory), or P (project — empty or has at least one non-dir
# immediate child). See plan §3.1, §3.2.
#
# Quoting: this snippet is interpolated into both the local-mode block (as
# direct shell code) and into the remote `bash --norc --noprofile -c '...'`
# wrapper (where every `$` that should reach the remote bash is escaped to
# `\$` and every double quote is escaped to `\"`). We keep two copies because
# the remote-mode escape conventions diverge enough that a single string with
# placeholder substitution would be more error-prone than two readable copies.

if (( LOCAL_MODE )); then
  RAW=$(
    {
      echo ---TREE---
      ( cd "$LOCAL_DIR" 2>/dev/null && {
          total=$(find . -maxdepth 8 -type d ! -path '*/.*' 2>/dev/null | wc -l | tr -d ' ')
          deeper=$(find . -mindepth 9 -type d ! -path '*/.*' 2>/dev/null | head -n 1)
          # Truncation: macOS BWK awk does not support -v RS='\0' (records get
          # collapsed). We instead count inside the bash while-loop and break
          # at 2000 — portable across BWK awk, GNU awk, and bash 3.2.
          i=0
          find . -maxdepth 8 -type d ! -path '*/.*' -print0 2>/dev/null \
            | while IFS= read -r -d '' p; do
                i=$(( i + 1 ))
                [ "$i" -gt 2000 ] && break
                rel="${p#./}"
                [ "$p" = "." ] && rel="."
                # 5-type classification (server-side):
                #   R = synthetic root (only the `.` row)
                #   P = has CLAUDE.md (regular file, not symlink/dir)
                #   S = no CLAUDE.md AND basename ends with _suite
                #   F = no CLAUDE.md AND any other basename
                # H/M are synthesized client-side from P rows by the parser.
                if [ "$rel" = "." ]; then
                  t=R
                elif [ -f "$p/CLAUDE.md" ]; then
                  t=P
                else
                  # bash 3.2 mis-parses `case` inside `$(...)`; use a string
                  # suffix test instead. ${VAR%%PATTERN} strips the longest
                  # matching suffix; if it changes, the suffix matched.
                  base="${p##*/}"
                  if [ "${base%_suite}" != "$base" ]; then
                    t=S
                  else
                    t=F
                  fi
                fi
                # Compute n_all (immediate child count) only for F/S — used in
                # picker `(N)` annotation. Projects/Hubs/Members never display
                # a child count, so we skip the glob loop for those.
                n_all=0
                if [ "$t" = "F" ] || [ "$t" = "S" ] || [ "$t" = "R" ]; then
                  for c in "$p"/* "$p"/.[!.]* "$p"/..?* ; do
                    [ -e "$c" ] || continue
                    n_all=$(( n_all + 1 ))
                  done
                fi
                printf '%s\t%s\t%s\n' "$rel" "$t" "$n_all"
              done
          [ "$total" -gt 2000 ] && echo ---TRUNCATED---
          [ -n "$deeper" ] && echo ---DEPTH-TRUNCATED---
        } )
      echo ---TMUX---
      tmux list-sessions -F "#{session_name} #{session_activity}" 2>/dev/null || true
    }
  )
else
  # shellcheck disable=SC2029
  if ! RAW=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
    cd ${PROJECTS_DIR} 2>/dev/null || exit 0
    echo ---TREE---
    total=\$(find . -maxdepth 8 -type d ! -path \"*/.*\" 2>/dev/null | wc -l | tr -d \" \")
    deeper=\$(find . -mindepth 9 -type d ! -path \"*/.*\" 2>/dev/null | head -n 1)
    i=0
    find . -maxdepth 8 -type d ! -path \"*/.*\" -print0 2>/dev/null \
      | while IFS= read -r -d \"\" p; do
          i=\$(( i + 1 ))
          [ \"\$i\" -gt 2000 ] && break
          rel=\"\${p#./}\"
          [ \"\$p\" = \".\" ] && rel=\".\"
          if [ \"\$rel\" = \".\" ]; then
            t=R
          elif [ -f \"\$p/CLAUDE.md\" ]; then
            t=P
          else
            case \"\${p##*/}\" in
              *_suite) t=S ;;
              *)       t=F ;;
            esac
          fi
          n_all=0
          if [ \"\$t\" = \"F\" ] || [ \"\$t\" = \"S\" ] || [ \"\$t\" = \"R\" ]; then
            for c in \"\$p\"/* \"\$p\"/.[!.]* \"\$p\"/..?* ; do
              [ -e \"\$c\" ] || continue
              n_all=\$(( n_all + 1 ))
            done
          fi
          printf \"%s\\t%s\\t%s\\n\" \"\$rel\" \"\$t\" \"\$n_all\"
        done
    [ \"\$total\" -gt 2000 ] && echo ---TRUNCATED---
    [ -n \"\$deeper\" ] && echo ---DEPTH-TRUNCATED---
    echo ---TMUX---
    tmux list-sessions -F \"#{session_name} #{session_activity}\" 2>/dev/null || true
  '" 2>/dev/null); then
    echo "claudehome: cannot reach ${REMOTE_USER}@${HOST} over SSH." >&2
    echo "  - Check Tailscale is up on both devices:   tailscale status" >&2
    echo "  - Check Mac mini Remote Login is enabled:  System Settings → General → Sharing" >&2
    echo "  - Check your SSH key is authorized on the Mac mini." >&2
    exit 1
  fi
fi

# Split RAW into tree and tmux blocks. The pre-`---TREE---` slice (banner /
# stray output) is discarded.
TREE_BLOCK="${RAW#*---TREE---}"
TREE_BLOCK="${TREE_BLOCK%%---TMUX---*}"
TMUX_BLOCK="${RAW#*---TMUX---}"

# ---- parse tree rows ----
# Populates four parallel arrays keyed by row index:
#   TREE_PATH[i]      — relative path (e.g. "work/client-a/site"; "." for synthetic root)
#   TREE_TYPE[i]      — "R" (synthetic root), "F" (Folder), "S" (Suite),
#                       "P" (Project, no Suite ancestor), "H" (Hub: parent is
#                       Suite + basename ends _hub), or "M" (Member: has Suite
#                       ancestor, not a Hub). H/M are synthesized by
#                       post_classify_tree from server-emitted P rows.
#   TREE_CHILDREN[i]  — immediate-child count (integer)
#   TREE_PARENT[i]    — parent path ("" for top-level rows; "" for "." root)
#
# Wire-format invariant: every emitted path matches
# `^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$` OR is exactly `.`. Rows that fail are
# silently dropped; a single deduped stderr warning is printed per session.
TREE_PATH=()
TREE_TYPE=()
TREE_CHILDREN=()
TREE_PARENT=()
TRUNCATED_ROWS=0
TRUNCATED_DEPTH=0
SKIPPED_BAD_PATHS=0

NOW=$(date +%s)

while IFS= read -r row; do
  [[ -z "$row" ]] && continue
  case "$row" in
    '---TRUNCATED---')      TRUNCATED_ROWS=1;  continue ;;
    '---DEPTH-TRUNCATED---') TRUNCATED_DEPTH=1; continue ;;
  esac
  # TAB-split into three fields.
  IFS=$'\t' read -r tp tt tc <<< "$row"
  [[ -z "${tp:-}" || -z "${tt:-}" ]] && continue
  # Enforce wire-format invariant. A TAB or newline embedded in an on-disk
  # directory name corrupts the wire format mid-row: the first segment lands
  # in $tp (and may pass the allowlist regex), but the type field $tt then
  # holds garbage. Reject any row whose type is not R/F/S/P/H/M, which catches
  # the TAB-in-name case the path allowlist misses. The server only emits
  # R/F/S/P; H/M are synthesized client-side below — but the regex permits
  # them so test fixtures can inject hand-crafted H/M rows.
  if [[ ! "$tt" =~ ^[RFSPHM]$ ]]; then
    SKIPPED_BAD_PATHS=$(( SKIPPED_BAD_PATHS + 1 ))
    continue
  fi
  if [[ "$tp" != "." && ! "$tp" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
    SKIPPED_BAD_PATHS=$(( SKIPPED_BAD_PATHS + 1 ))
    continue
  fi
  # Compute parent.
  if [[ "$tp" == "." ]]; then
    parent=""
  elif [[ "$tp" == */* ]]; then
    parent="${tp%/*}"
  else
    parent=""
  fi
  TREE_PATH+=("$tp")
  TREE_TYPE+=("$tt")
  TREE_CHILDREN+=("${tc:-0}")
  TREE_PARENT+=("$parent")
done <<< "$TREE_BLOCK"

# post_classify_tree
# Walks the parsed TREE_* arrays in two passes:
#   1. For each P-row, if any ancestor segment ends `_suite`, promote to M
#      (Member). If additionally the immediate parent ends `_suite` AND the
#      row's basename ends `_hub`, promote to H (Hub) instead. Spec §3.2.
#   2. For each S-row whose ancestor chain contains a `_suite` segment, demote
#      to F (Folder) and warn — nested Suites are unsupported in v1. AC-5T7.
# Idempotent: safe to call after refetch_tree as well.
post_classify_tree() {
  local i j n_rows=${#TREE_PATH[@]}
  for (( i=0; i<n_rows; i++ )); do
    [[ "${TREE_TYPE[$i]}" != "P" ]] && continue
    local p="${TREE_PATH[$i]}"
    local segs
    IFS='/' read -ra segs <<< "$p"
    local n_segs=${#segs[@]}
    local has_suite_ancestor=0
    local parent_is_suite=0
    # Walk segments[0..n_segs-2] (every ancestor — exclude the row itself).
    for (( j=0; j<n_segs-1; j++ )); do
      if [[ "${segs[$j]}" == *_suite ]]; then
        has_suite_ancestor=1
        # parent_is_suite if the suite is the IMMEDIATE parent (j == n_segs-2).
        (( j == n_segs - 2 )) && parent_is_suite=1
      fi
    done
    if (( has_suite_ancestor )); then
      local row_basename="${segs[$n_segs-1]}"
      if (( parent_is_suite )) && [[ "$row_basename" == *_hub ]]; then
        TREE_TYPE[i]=H
      else
        TREE_TYPE[i]=M
      fi
    fi
    # else: stays P (no Suite ancestor anywhere)
  done

  # Second pass: nested-Suite demotion. Walk all S-rows; if any ancestor ends
  # `_suite`, demote to F and emit one stderr warning per offending path.
  for (( i=0; i<n_rows; i++ )); do
    [[ "${TREE_TYPE[$i]}" != "S" ]] && continue
    local p="${TREE_PATH[$i]}"
    local segs
    IFS='/' read -ra segs <<< "$p"
    local n_segs=${#segs[@]}
    for (( j=0; j<n_segs-1; j++ )); do
      if [[ "${segs[$j]}" == *_suite ]]; then
        TREE_TYPE[i]=F
        warn "nested Suites not supported; treating $p as Folder"
        break
      fi
    done
  done
}

post_classify_tree

if (( SKIPPED_BAD_PATHS > 0 )); then
  echo "claudehome: skipped ${SKIPPED_BAD_PATHS} path with disallowed characters — rename on the mini to surface it" >&2
fi
if (( TRUNCATED_ROWS )); then
  echo "claudehome: tree truncated at 2000 entries — clean up your projects dir" >&2
fi
if (( TRUNCATED_DEPTH )); then
  echo "claudehome: tree depth >8 not shown — reorganize on the mini" >&2
fi

# ---- helpers shared by drill loop ----

# Look up tmux session activity for a basename. Sets ACT_TS (timestamp string,
# empty if idle) and ACT_LABEL (human "5m ago" string, empty if idle).
_session_activity() {
  local basename=$1
  ACT_TS=$(awk -v s="claudehome-${basename}" '$1==s { print $2; exit }' <<< "$TMUX_BLOCK")
  ACT_LABEL=
  if [[ -n "${ACT_TS:-}" ]]; then
    local age=$(( NOW - ACT_TS ))
    (( age < 0 )) && age=0   # clamp client-vs-server clock skew
    if   (( age < 60 ));    then ACT_LABEL="${age}s ago"
    elif (( age < 3600 ));  then ACT_LABEL="$(( age / 60 ))m ago"
    elif (( age < 86400 )); then ACT_LABEL="$(( age / 3600 ))h ago"
    else                         ACT_LABEL="$(( age / 86400 ))d ago"
    fi
  fi
}

# ---- build_rows_for_path(path) ----
# Filters TREE_* arrays to direct children of $path and populates three
# parallel arrays of picker rows:
#   PICKER_LINES[]    — display strings (what fzf/select see)
#   PICKER_KIND[]     — one of: back / folder / project / new_anything
#                        (folder kind = drillable: F or S)
#                        (project kind = attachable: P, H, or M)
#   PICKER_PAYLOAD[]  — full path for folder/project, "" for back/new_anything
#
# Row order:
#   1. [..  back]   (non-root only)
#   2. Folders + Suites alphabetically interleaved by basename
#   3. Projects + Hubs + Members active-then-idle
#   4. [new...]     (always last)
#
# 5-type rendering:
#   Folder:  <name>/  (N)
#   Suite:   <name>_suite/  (N)
#   Project: <name>  [active <ts>] | <name>  [idle]
#   Hub:     <name>_hub  HUB  [active <ts>] | <name>_hub  HUB  [idle]
#   Member:  <name>  member  [active <ts>] | <name>  member  [idle]
build_rows_for_path() {
  local path=$1
  PICKER_LINES=()
  PICKER_KIND=()
  PICKER_PAYLOAD=()

  # [..  back] for non-root frames.
  if [[ -n "$path" ]]; then
    PICKER_LINES+=("[..  back]")
    PICKER_KIND+=("back")
    PICKER_PAYLOAD+=("")
  fi

  local i n n_rows=${#TREE_PATH[@]}
  local folder_lines=() folder_paths=()
  local active_lines=() active_keys=() active_paths=()
  local idle_lines=() idle_paths=()

  local match_parent="$path"

  for (( i=0; i<n_rows; i++ )); do
    local p="${TREE_PATH[$i]}"
    local t="${TREE_TYPE[$i]}"
    local par="${TREE_PARENT[$i]}"
    # Skip the synthetic root row itself.
    [[ "$p" == "." ]] && continue
    [[ "$par" != "$match_parent" ]] && continue
    local basename="${p##*/}"
    case "$t" in
      F)
        n="${TREE_CHILDREN[$i]}"
        folder_lines+=("${basename}/  (${n})")
        folder_paths+=("$p")
        ;;
      S)
        n="${TREE_CHILDREN[$i]}"
        # Suite renders as `<name>_suite/  (N)` — the `_suite` suffix is
        # already part of $basename. Folders + Suites interleave by basename.
        folder_lines+=("${basename}/  (${n})")
        folder_paths+=("$p")
        ;;
      P|H|M)
        # Compute badge column. The badge sits between basename and activity.
        local badge=""
        case "$t" in
          H) badge="HUB" ;;
          M) badge="member" ;;
        esac
        _session_activity "$basename"
        local act_col
        if [[ -n "${ACT_TS:-}" ]]; then
          act_col="[active ${ACT_LABEL}]"
        else
          act_col="[idle]"
        fi
        # Build display line: <basename>  [<badge>  ]<act_col>
        local line
        if [[ -n "$badge" ]]; then
          line="${basename}  ${badge}  ${act_col}"
        else
          line="${basename}  ${act_col}"
        fi
        if [[ -n "${ACT_TS:-}" ]]; then
          active_lines+=("$line")
          active_keys+=("${ACT_TS}")
          active_paths+=("$p")
        else
          idle_lines+=("$line")
          idle_paths+=("$p")
        fi
        ;;
    esac
  done

  # Sort folders + suites alphabetically by basename — interleaved (no
  # separation between F and S). Tagged sort on the display line.
  if (( ${#folder_lines[@]} > 0 )); then
    local sorted
    sorted=$(
      local k
      for (( k=0; k<${#folder_lines[@]}; k++ )); do
        printf '%s\t%s\n' "${folder_lines[$k]}" "${folder_paths[$k]}"
      done | LC_ALL=C sort
    )
    while IFS=$'\t' read -r fline fpath; do
      [[ -z "$fline" ]] && continue
      PICKER_LINES+=("$fline")
      PICKER_KIND+=("folder")
      PICKER_PAYLOAD+=("$fpath")
    done <<< "$sorted"
  fi

  # Active projects/hubs/members descending by activity timestamp.
  if (( ${#active_lines[@]} > 0 )); then
    local sorted
    sorted=$(
      local k
      for (( k=0; k<${#active_lines[@]}; k++ )); do
        printf '%s\t%s\t%s\n' "${active_keys[$k]}" "${active_lines[$k]}" "${active_paths[$k]}"
      done | LC_ALL=C sort -t$'\t' -k1,1nr -k2,2
    )
    while IFS=$'\t' read -r _ts aline apath; do
      [[ -z "${aline:-}" ]] && continue
      PICKER_LINES+=("$aline")
      PICKER_KIND+=("project")
      PICKER_PAYLOAD+=("$apath")
    done <<< "$sorted"
  fi

  # Idle projects/hubs/members alphabetical by display line (basename-prefix).
  if (( ${#idle_lines[@]} > 0 )); then
    local sorted
    sorted=$(
      local k
      for (( k=0; k<${#idle_lines[@]}; k++ )); do
        printf '%s\t%s\n' "${idle_lines[$k]}" "${idle_paths[$k]}"
      done | LC_ALL=C sort
    )
    while IFS=$'\t' read -r iline ipath; do
      [[ -z "$iline" ]] && continue
      PICKER_LINES+=("$iline")
      PICKER_KIND+=("project")
      PICKER_PAYLOAD+=("$ipath")
    done <<< "$sorted"
  fi

  # Always-last [new...] row. Triggers context-aware type prompt.
  PICKER_LINES+=("[new...]")
  PICKER_KIND+=("new_anything")
  PICKER_PAYLOAD+=("")
}

# ---- pick_one ----
# Renders PICKER_LINES via fzf (preferred) or bash select (fallback).
# Sets globals SELECTED_KIND and SELECTED_PAYLOAD by looking up the picked
# line's index in PICKER_LINES. Sets SELECTED_KIND=cancel on Ctrl-D / empty.
pick_one() {
  SELECTED_KIND=
  SELECTED_PAYLOAD=
  local picked=
  if command -v fzf >/dev/null 2>&1; then
    if ! picked=$(printf '%s\n' "${PICKER_LINES[@]}" | fzf --prompt='claudehome> ' --height=~50% --reverse); then
      SELECTED_KIND=cancel
      return 0
    fi
  else
    local PS3='Select: '
    select picked in "${PICKER_LINES[@]}"; do
      [[ -n "${picked:-}" ]] && break
    done
    if [[ -z "${picked:-}" ]]; then
      SELECTED_KIND=cancel
      return 0
    fi
  fi
  # Look up the index by line.
  local i
  for (( i=0; i<${#PICKER_LINES[@]}; i++ )); do
    if [[ "${PICKER_LINES[$i]}" == "$picked" ]]; then
      SELECTED_KIND="${PICKER_KIND[$i]}"
      SELECTED_PAYLOAD="${PICKER_PAYLOAD[$i]}"
      return 0
    fi
  done
  # No match (shouldn't happen) — treat as cancel.
  SELECTED_KIND=cancel
}

# ---- creation flows (5-type) ----
#
# `prompt_new_anything <parent_path>` is the single entry point for the
# `[new...]` picker row. It determines the parent's type, computes valid
# creation types from spec §3.3, prompts the user for a type then a name, and
# dispatches to a per-type `create_*` helper. Communicates with the caller via
# globals:
#   PROMPT_OK     — 1 on success, 0 on cancel/failure (errexit-safe).
#   PROMPT_NAME   — final basename created (with auto-suffix applied).
#   PROMPT_PARENT — parent path under which the row was created.
#   PROMPT_KIND   — "attach" if the new entry is attachable (project/hub/member),
#                   "folder" if it's a Folder/Suite (no attach).
#
# Sibling-collision and globally-unique checks live in shared helpers below.

# _validate_name <name> — set RES_OK=1 on accept, 0 with reason text on stderr.
# Enforces the allowlist + reserved-name rules used by all creation flows.
_validate_name() {
  local name=$1
  RES_OK=0
  if [[ -z "$name" ]]; then
    return 0
  fi
  if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo "  '${name}' has unsupported characters. Allowed: letters, digits, '.', '_', '-'. Try again." >&2
    return 0
  fi
  if [[ "$name" == "." || "$name" == ".." || "$name" == .* ]]; then
    echo "  '${name}' is reserved. Pick a different name." >&2
    return 0
  fi
  RES_OK=1
}

# _check_sibling_collision <parent_path> <name> — set RES_COLLIDE=1 if a row
# with the given basename already exists under $parent_path (any type).
_check_sibling_collision() {
  local parent=$1 name=$2
  RES_COLLIDE=0
  local i
  for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
    [[ "${TREE_PARENT[$i]}" != "$parent" ]] && continue
    local ex_basename="${TREE_PATH[$i]##*/}"
    if [[ "$ex_basename" == "$name" ]]; then
      RES_COLLIDE=1
      return 0
    fi
  done
}

# _check_global_unique <name> — set RES_CONFLICT to the conflicting full path
# if any P/H/M-type row anywhere in the tree shares the basename. Empty if no
# conflict. Used by project/hub/member creation; folder/suite creation skips
# this check (folders/suites are not globally unique).
_check_global_unique() {
  local name=$1
  RES_CONFLICT=
  local i
  for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
    local t="${TREE_TYPE[$i]}"
    [[ "$t" != "P" && "$t" != "H" && "$t" != "M" ]] && continue
    local ex_basename="${TREE_PATH[$i]##*/}"
    if [[ "$ex_basename" == "$name" ]]; then
      RES_CONFLICT="${TREE_PATH[$i]}"
      return 0
    fi
  done
}

# walk_to_suite_root <drill_path> — walk segments of $drill_path looking for
# the closest-to-root segment ending `_suite`. Sets RES_SUITE_ROOT to the
# accumulated path of that segment, or "" if none.
walk_to_suite_root() {
  local p=$1
  RES_SUITE_ROOT=
  [[ -z "$p" ]] && return 0
  local segs
  IFS='/' read -ra segs <<< "$p"
  local n=${#segs[@]} j acc=""
  for (( j=0; j<n; j++ )); do
    acc="${acc:+$acc/}${segs[$j]}"
    if [[ "${segs[$j]}" == *_suite ]]; then
      RES_SUITE_ROOT="$acc"
      return 0
    fi
  done
}

# detect_hub <suite_root_relpath> — count `*_hub` direct children of the Suite
# that have CLAUDE.md (i.e., are real Hubs). Sets RES_HUB_COUNT (integer) and
# RES_HUB_PATH (absolute filesystem path of the unique Hub when count == 1;
# empty otherwise). Operates on the local filesystem in LOCAL_MODE; SSHs to
# the remote in remote mode (one round-trip).
detect_hub() {
  local suite_rel=$1
  RES_HUB_COUNT=0
  RES_HUB_PATH=
  [[ -z "$suite_rel" ]] && return 0
  if (( LOCAL_MODE )); then
    local suite_abs="${LOCAL_DIR}/${suite_rel}"
    local h
    for h in "$suite_abs"/*_hub; do
      if [[ -d "$h" && -f "$h/CLAUDE.md" ]]; then
        RES_HUB_COUNT=$(( RES_HUB_COUNT + 1 ))
        RES_HUB_PATH="$h"
      fi
    done
    if (( RES_HUB_COUNT > 1 )); then
      RES_HUB_PATH=
    fi
  else
    # Remote: probe via SSH. Print "<count>\t<abs_path_or_empty>".
    local probe
    # shellcheck disable=SC2029
    probe=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
      "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
        cd ${PROJECTS_DIR} 2>/dev/null || exit 0
        suite=\"${suite_rel}\"
        n=0; first=
        for h in \"\$suite\"/*_hub; do
          [ -d \"\$h\" ] && [ -f \"\$h/CLAUDE.md\" ] || continue
          n=\$((n+1))
          [ -z \"\$first\" ] && first=\$(cd \"\$h\" 2>/dev/null && pwd -P)
        done
        printf \"%s\\t%s\\n\" \"\$n\" \"\$first\"
      '" 2>/dev/null) || probe=""
    if [[ -n "$probe" ]]; then
      local cnt path_line
      IFS=$'\t' read -r cnt path_line <<< "$probe"
      RES_HUB_COUNT="${cnt:-0}"
      if (( RES_HUB_COUNT == 1 )); then
        RES_HUB_PATH="${path_line:-}"
      fi
    fi
  fi
}

# prompt_description — read a single-line description from stdin. Sets
# RES_DESC; empty input yields the placeholder string. Embedded newlines are
# rejected with re-prompt.
prompt_description() {
  RES_DESC=
  local desc
  while :; do
    if ! read -r -p "One-line description (optional): " desc; then
      RES_DESC="<one-line description goes here>"
      return 0
    fi
    if [[ "$desc" == *$'\n'* ]]; then
      warn "description must be single-line"
      continue
    fi
    if [[ -z "$desc" ]]; then
      RES_DESC="<one-line description goes here>"
    else
      RES_DESC="$desc"
    fi
    return 0
  done
}

# _mkdir_remote_or_local <relpath> — idempotent mkdir under the projects root.
# Used by every creation helper that materializes a directory on disk.
_mkdir_remote_or_local() {
  local rel=$1
  if (( LOCAL_MODE )); then
    mkdir -p "${LOCAL_DIR}/${rel}"
  else
    # shellcheck disable=SC2029
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
      "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c 'mkdir -p ${PROJECTS_DIR}/${rel}'" >/dev/null 2>&1 \
      || warn "mkdir failed for ${rel}; continuing"
  fi
}

# create_folder <parent_path> <name> — mkdir the Folder, refetch the tree.
# Sets PROMPT_OK=1 on success, PROMPT_KIND="folder", PROMPT_PARENT/PROMPT_NAME.
create_folder() {
  local parent=$1 name=$2
  local rel="${parent:+$parent/}${name}"
  _mkdir_remote_or_local "$rel"
  refetch_tree
  PROMPT_OK=1
  PROMPT_KIND=folder
  PROMPT_PARENT="$parent"
  PROMPT_NAME="$name"
}

# create_suite <parent_path> <prefix> — mkdir the Suite (auto-appending _suite),
# refetch the tree.
create_suite() {
  local parent=$1 prefix=$2
  local final="${prefix}_suite"
  local rel="${parent:+$parent/}${final}"
  _mkdir_remote_or_local "$rel"
  refetch_tree
  PROMPT_OK=1
  PROMPT_KIND=folder
  PROMPT_PARENT="$parent"
  PROMPT_NAME="$final"
}

# create_project <parent_path> <name> — record the new project for attach. The
# attach branch creates the directory + tmux session. We also write a minimal
# CLAUDE.md so re-runs classify it as Project (otherwise it'd be Folder per
# the new heuristic).
create_project() {
  local parent=$1 name=$2
  local rel="${parent:+$parent/}${name}"
  _mkdir_remote_or_local "$rel"
  _write_minimal_claude_md "$rel" "$name"
  PROMPT_OK=1
  PROMPT_KIND=attach
  PROMPT_PARENT="$parent"
  PROMPT_NAME="$name"
}

# create_hub <parent_path> <prefix> — Suite-with-Hub creation. mkdir the Hub
# (auto-appending _hub), write CLAUDE.md, README.md template, projects.md
# header. The Hub is then attachable like any P/H/M.
create_hub() {
  local parent=$1 prefix=$2
  local final="${prefix}_hub"
  local rel="${parent:+$parent/}${final}"
  _mkdir_remote_or_local "$rel"
  _write_hub_scaffold "$rel" "$final"
  PROMPT_OK=1
  PROMPT_KIND=attach
  PROMPT_PARENT="$parent"
  PROMPT_NAME="$final"
}

# create_member <parent_path> <name> <suite_root_relpath> — full hub-aware
# Member creation. mkdir, optionally git init + @-import CLAUDE.md +
# projects.md row when exactly one Hub exists at the Suite root. On Multi-Hub
# or no-Hub, falls back to a plain `# <name>\n` CLAUDE.md.
create_member() {
  local parent=$1 name=$2 suite_root=$3
  local rel="${parent:+$parent/}${name}"
  _mkdir_remote_or_local "$rel"

  # Detect Hub at the Suite root.
  detect_hub "$suite_root"
  local hub_count="$RES_HUB_COUNT"
  local hub_path="$RES_HUB_PATH"

  if (( hub_count == 0 )); then
    # No Hub: plain CLAUDE.md, no description prompt, no scaffolding.
    _write_minimal_claude_md "$rel" "$name"
  elif (( hub_count >= 2 )); then
    # Multi-Hub: warn and fall back to plain.
    local suite_abs
    if (( LOCAL_MODE )); then
      suite_abs="${LOCAL_DIR}/${suite_root}"
    else
      suite_abs="${PROJECTS_DIR}/${suite_root}"
    fi
    warn "multiple *_hub siblings found in ${suite_abs}; skipping hub-aware writes"
    _write_minimal_claude_md "$rel" "$name"
  else
    # Exactly one Hub: full hub-aware scaffolding.
    prompt_description
    local desc="$RES_DESC"
    _hub_aware_writes "$rel" "$name" "$hub_path" "$desc"
  fi

  PROMPT_OK=1
  PROMPT_KIND=attach
  PROMPT_PARENT="$parent"
  PROMPT_NAME="$name"
}

# _write_minimal_claude_md <relpath> <name> — write `# <name>\n` to
# <projects_root>/<relpath>/CLAUDE.md. Idempotent — safe to call repeatedly.
_write_minimal_claude_md() {
  local rel=$1 name=$2
  if (( LOCAL_MODE )); then
    local path="${LOCAL_DIR}/${rel}/CLAUDE.md"
    [[ -f "$path" ]] && return 0
    printf '# %s\n' "$name" > "$path" 2>/dev/null || warn "write failed for ${rel}/CLAUDE.md"
  else
    # shellcheck disable=SC2029
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
      "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
        f=${PROJECTS_DIR}/${rel}/CLAUDE.md
        [ -f \"\$f\" ] || printf \"# %s\\n\" \"${name}\" > \"\$f\"
      '" >/dev/null 2>&1 || warn "write failed for ${rel}/CLAUDE.md"
  fi
}

# _write_hub_scaffold <relpath> <hub_name> — write Hub CLAUDE.md, README.md,
# and projects.md header. Idempotent on per-file basis (skip if file exists).
_write_hub_scaffold() {
  local rel=$1 hub_name=$2
  if (( LOCAL_MODE )); then
    local hub_abs="${LOCAL_DIR}/${rel}"
    [[ -f "$hub_abs/CLAUDE.md" ]]   || printf '# %s\n' "$hub_name"          > "$hub_abs/CLAUDE.md"   2>/dev/null || warn "write failed for ${rel}/CLAUDE.md"
    [[ -f "$hub_abs/README.md" ]]   || printf '# %s\n\nHub README.\n' "$hub_name" > "$hub_abs/README.md" 2>/dev/null || warn "write failed for ${rel}/README.md"
    if [[ ! -f "$hub_abs/projects.md" ]]; then
      {
        printf '| Name | Description | Status | Owner | Notes |\n'
        printf '|------|-------------|--------|-------|-------|\n'
      } > "$hub_abs/projects.md" 2>/dev/null || warn "write failed for ${rel}/projects.md"
    fi
  else
    # Remote: one SSH round-trip with all three writes.
    # shellcheck disable=SC2029
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
      "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
        d=${PROJECTS_DIR}/${rel}
        [ -f \"\$d/CLAUDE.md\" ]   || printf \"# %s\\n\" \"${hub_name}\" > \"\$d/CLAUDE.md\"
        [ -f \"\$d/README.md\" ]   || printf \"# %s\\n\\nHub README.\\n\" \"${hub_name}\" > \"\$d/README.md\"
        if [ ! -f \"\$d/projects.md\" ]; then
          {
            printf \"| Name | Description | Status | Owner | Notes |\\n\"
            printf \"|------|-------------|--------|-------|-------|\\n\"
          } > \"\$d/projects.md\"
        fi
      '" >/dev/null 2>&1 || warn "hub scaffold write failed for ${rel}"
  fi
}

# _hub_aware_writes <member_rel> <member_name> <hub_abs> <description> —
# the four hub-aware writes for a Member. All warn-and-continue; never abort.
#   1. git init in the member directory
#   2. write CLAUDE.md with @-import to the Hub README
#   3. append a row to <hub>/projects.md (only if it exists and is non-empty)
# _sq_escape <string> — escape every `'` for safe inclusion inside a single-
# quoted bash context. The bash idiom is to close the quote, write an escaped
# quote, then reopen: '\''. Used by _hub_aware_writes for the description
# (which is free user text and CANNOT be allowlist-restricted; name/hub_abs
# are already validated against [a-zA-Z0-9._-]+ so they cannot contain `'`).
# Without this escape, a malicious description like "x'; rm -rf ~; echo '"
# would close the outer `bash -c '...'` quote and execute arbitrary commands
# on the mini under REMOTE_USER (verified RCE; security review iter-1 finding).
_sq_escape() {
  printf %s "$1" | sed "s/'/'\\\\''/g"
}

_hub_aware_writes() {
  local rel=$1 name=$2 hub_abs=$3 desc=$4
  local desc_pipe_escaped="${desc//|/\\|}"
  if (( LOCAL_MODE )); then
    local member_abs="${LOCAL_DIR}/${rel}"
    ( cd "$member_abs" 2>/dev/null && git init >/dev/null 2>&1 ) \
      || warn "git init failed for ${rel}; .git/ not initialized"
    {
      printf '# %s\n\n' "$name"
      printf '@%s/README.md\n\n' "$hub_abs"
      printf '%s\n' "$desc"
    } > "$member_abs/CLAUDE.md" 2>/dev/null \
      || warn "write failed for ${rel}/CLAUDE.md"
    if [[ -s "$hub_abs/projects.md" ]]; then
      printf '| %s | %s | active | — | — |\n' "$name" "$desc_pipe_escaped" \
        >> "$hub_abs/projects.md" 2>/dev/null \
        || warn "append failed for ${hub_abs}/projects.md"
    else
      warn "${hub_abs}/projects.md missing or empty; row not appended"
    fi
  else
    # Escape single quotes in user-supplied free text before splicing into
    # the outer `bash -c '...'` quoted command. Without this, a `'` in $desc
    # would close the outer quote and allow arbitrary command execution on
    # the mini.
    local desc_sq desc_pipe_sq
    desc_sq=$(_sq_escape "$desc")
    desc_pipe_sq=$(_sq_escape "$desc_pipe_escaped")
    # shellcheck disable=SC2029
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
      "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
        member=${PROJECTS_DIR}/${rel}
        hub=\"${hub_abs}\"
        ( cd \"\$member\" 2>/dev/null && git init >/dev/null 2>&1 ) || true
        {
          printf \"# %s\\n\\n\" \"${name}\"
          printf \"@%s/README.md\\n\\n\" \"\$hub\"
          printf \"%s\\n\" \"${desc_sq}\"
        } > \"\$member/CLAUDE.md\"
        if [ -s \"\$hub/projects.md\" ]; then
          printf \"| %s | %s | active | — | — |\\n\" \"${name}\" \"${desc_pipe_sq}\" >> \"\$hub/projects.md\"
        fi
      '" >/dev/null 2>&1 || warn "hub-aware writes failed for ${rel}"
  fi
}

# _read_type_choice <valid_types> — pick a creation-type from a space-
# separated list. Prefers an fzf arrow-key picker when fzf is on PATH;
# falls back to a typed prompt with substring-prefix matching when not.
# Sets RES_TYPE on accept; empty/Ctrl-C/Ctrl-D sets RES_TYPE="".
_read_type_choice() {
  local valid_types=$1
  RES_TYPE=
  if command -v fzf >/dev/null 2>&1; then
    local picked
    # shellcheck disable=SC2086 # word-splitting on $valid_types is intentional
    picked=$(printf '%s\n' $valid_types | fzf --prompt='Create what? > ' --height=~30% --reverse --no-info) || return 0
    [[ -z "$picked" ]] && return 0
    RES_TYPE="$picked"
    return 0
  fi
  # Fallback (no fzf): typed prompt with full-word OR unique-prefix match.
  local input
  while :; do
    if ! read -r -p "Create what? [$valid_types]: " input; then
      return 0
    fi
    if [[ -z "$input" ]]; then
      return 0
    fi
    local matched=
    local v
    for v in $valid_types; do
      if [[ "$v" == "$input" ]]; then
        matched="$v"
        break
      fi
    done
    if [[ -z "$matched" ]]; then
      for v in $valid_types; do
        if [[ "$v" == "$input"* ]]; then
          if [[ -n "$matched" ]]; then
            matched=AMBIGUOUS
            break
          fi
          matched="$v"
        fi
      done
    fi
    if [[ -z "$matched" || "$matched" == AMBIGUOUS ]]; then
      warn "invalid type '${input}'; expected one of: ${valid_types}"
      continue
    fi
    RES_TYPE="$matched"
    return 0
  done
}

# prompt_new_anything <parent_path>
# Single dispatch point for the [new...] picker row. See spec §3.3.
prompt_new_anything() {
  local parent=$1
  PROMPT_OK=0
  PROMPT_KIND=
  PROMPT_PARENT=
  PROMPT_NAME=

  # 1. Determine parent type. The picker only drills into R/F/S, so the
  # parent here is one of R (root, parent==""), F, or S. Any other type is
  # an internal error.
  local parent_type=
  if [[ -z "$parent" ]]; then
    parent_type=R
  else
    local i
    for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
      if [[ "${TREE_PATH[$i]}" == "$parent" ]]; then
        parent_type="${TREE_TYPE[$i]}"
        break
      fi
    done
  fi
  if [[ "$parent_type" != R && "$parent_type" != F && "$parent_type" != S ]]; then
    warn "[new...] not available at this drill level"
    return 0
  fi

  # 2. Compute valid creation types from parent type.
  # F-type is structurally ambiguous (plain Folder vs sub-Folder inside Suite),
  # so walk_to_suite_root first to disambiguate. S-type is always at a Suite
  # root; check for existing Hub via detect_hub.
  local suite_root="" valid_types=""
  case "$parent_type" in
    R) valid_types="folder suite project" ;;
    F)
      walk_to_suite_root "$parent"
      suite_root="$RES_SUITE_ROOT"
      if [[ -n "$suite_root" ]]; then
        valid_types="folder member"
      else
        valid_types="folder project"
      fi
      ;;
    S)
      suite_root="$parent"
      detect_hub "$suite_root"
      if (( RES_HUB_COUNT == 0 )); then
        valid_types="folder member hub"
      else
        valid_types="folder member"
      fi
      ;;
  esac

  # 3. Prompt for type.
  _read_type_choice "$valid_types"
  local type="$RES_TYPE"
  [[ -z "$type" ]] && return 0

  # 4. Prompt for name (loop on validation errors).
  local name=
  while :; do
    case "$type" in
      folder)  read -r -p "New folder name: "  name || return 0 ;;
      project) read -r -p "New project name: " name || return 0 ;;
      suite)   read -r -p "New suite name (suffix _suite is auto-appended): " name || return 0 ;;
      hub)     read -r -p "New hub name (suffix _hub is auto-appended): "     name || return 0 ;;
      member)  read -r -p "New member name: "  name || return 0 ;;
    esac
    [[ -z "$name" ]] && return 0

    # Suite/Hub: reject any user-typed `_suite`/`_hub` substring, then
    # auto-append the suffix on validation pass.
    case "$type" in
      suite)
        case "$name" in
          *_suite|*_suite_*)
            warn "name '_suite' substring not allowed; type just the prefix and the suffix is auto-appended."
            continue ;;
        esac
        ;;
      hub)
        case "$name" in
          *_hub|*_hub_*)
            warn "name '_hub' substring not allowed; type just the prefix and the suffix is auto-appended."
            continue ;;
        esac
        ;;
    esac

    _validate_name "$name"
    if (( ! RES_OK )); then
      [[ -z "$name" ]] && return 0
      continue
    fi

    # final_name is what actually lands on disk (after auto-suffix).
    local final_name="$name"
    case "$type" in
      suite) final_name="${name}_suite" ;;
      hub)   final_name="${name}_hub" ;;
    esac

    # Sibling collision check (any type at the same parent).
    _check_sibling_collision "$parent" "$final_name"
    if (( RES_COLLIDE )); then
      local where="${parent:+$parent/}${final_name}"
      echo "  '${final_name}' already exists at ${where}. Pick a different name." >&2
      continue
    fi

    # Globally-unique scan for project/hub/member basenames.
    case "$type" in
      project|hub|member)
        _check_global_unique "$final_name"
        if [[ -n "$RES_CONFLICT" ]]; then
          echo "  '${final_name}' already exists at ${RES_CONFLICT}. Pick a different name." >&2
          continue
        fi
        ;;
    esac

    # 5. Dispatch to type-specific creator. Each sets PROMPT_OK + companions.
    case "$type" in
      folder)  create_folder  "$parent" "$final_name" ;;
      suite)   create_suite   "$parent" "$name" ;;
      project) create_project "$parent" "$final_name" ;;
      hub)     create_hub     "$parent" "$name" ;;
      member)  create_member  "$parent" "$final_name" "$suite_root" ;;
    esac
    return 0
  done
}

# refetch_tree
# Re-runs the tree-walk emitter and re-parses TREE_* arrays. Used after a
# folder creation so the new folder is visible in the next picker render.
# Performance note: a re-fetch is one local find or one SSH round-trip; the
# user already paid for one tree walk on startup, so a second one after
# folder creation is acceptable.
refetch_tree() {
  local fresh
  if (( LOCAL_MODE )); then
    fresh=$(
      {
        echo ---TREE---
        ( cd "$LOCAL_DIR" 2>/dev/null && {
            total=$(find . -maxdepth 8 -type d ! -path '*/.*' 2>/dev/null | wc -l | tr -d ' ')
            deeper=$(find . -mindepth 9 -type d ! -path '*/.*' 2>/dev/null | head -n 1)
            i=0
            find . -maxdepth 8 -type d ! -path '*/.*' -print0 2>/dev/null \
              | while IFS= read -r -d '' p; do
                  i=$(( i + 1 ))
                  [ "$i" -gt 2000 ] && break
                  rel="${p#./}"
                  [ "$p" = "." ] && rel="."
                  if [ "$rel" = "." ]; then
                    t=R
                  elif [ -f "$p/CLAUDE.md" ]; then
                    t=P
                  else
                    base="${p##*/}"
                    if [ "${base%_suite}" != "$base" ]; then
                      t=S
                    else
                      t=F
                    fi
                  fi
                  n_all=0
                  if [ "$t" = "F" ] || [ "$t" = "S" ] || [ "$t" = "R" ]; then
                    for c in "$p"/* "$p"/.[!.]* "$p"/..?* ; do
                      [ -e "$c" ] || continue
                      n_all=$(( n_all + 1 ))
                    done
                  fi
                  printf '%s\t%s\t%s\n' "$rel" "$t" "$n_all"
                done
            [ "$total" -gt 2000 ] && echo ---TRUNCATED---
            [ -n "$deeper" ] && echo ---DEPTH-TRUNCATED---
          } )
        echo ---TMUX---
        tmux list-sessions -F "#{session_name} #{session_activity}" 2>/dev/null || true
      }
    )
  else
    # shellcheck disable=SC2029
    fresh=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
      cd ${PROJECTS_DIR} 2>/dev/null || exit 0
      echo ---TREE---
      total=\$(find . -maxdepth 8 -type d ! -path \"*/.*\" 2>/dev/null | wc -l | tr -d \" \")
      deeper=\$(find . -mindepth 9 -type d ! -path \"*/.*\" 2>/dev/null | head -n 1)
      i=0
      find . -maxdepth 8 -type d ! -path \"*/.*\" -print0 2>/dev/null \
        | while IFS= read -r -d \"\" p; do
            i=\$(( i + 1 ))
            [ \"\$i\" -gt 2000 ] && break
            rel=\"\${p#./}\"
            [ \"\$p\" = \".\" ] && rel=\".\"
            if [ \"\$rel\" = \".\" ]; then
              t=R
            elif [ -f \"\$p/CLAUDE.md\" ]; then
              t=P
            else
              case \"\${p##*/}\" in
                *_suite) t=S ;;
                *)       t=F ;;
              esac
            fi
            n_all=0
            if [ \"\$t\" = \"F\" ] || [ \"\$t\" = \"S\" ] || [ \"\$t\" = \"R\" ]; then
              for c in \"\$p\"/* \"\$p\"/.[!.]* \"\$p\"/..?* ; do
                [ -e \"\$c\" ] || continue
                n_all=\$(( n_all + 1 ))
              done
            fi
            printf \"%s\\t%s\\t%s\\n\" \"\$rel\" \"\$t\" \"\$n_all\"
          done
      [ \"\$total\" -gt 2000 ] && echo ---TRUNCATED---
      [ -n \"\$deeper\" ] && echo ---DEPTH-TRUNCATED---
      echo ---TMUX---
      tmux list-sessions -F \"#{session_name} #{session_activity}\" 2>/dev/null || true
    '" 2>/dev/null) || {
      echo "claudehome: tree refresh failed; using cached view" >&2
      return 0
    }
  fi
  # Re-parse into TREE_* arrays.
  local body="${fresh#*---TREE---}"
  body="${body%%---TMUX---*}"
  TMUX_BLOCK="${fresh#*---TMUX---}"
  TREE_PATH=()
  TREE_TYPE=()
  TREE_CHILDREN=()
  TREE_PARENT=()
  while IFS= read -r row; do
    [[ -z "$row" ]] && continue
    case "$row" in
      '---TRUNCATED---'|'---DEPTH-TRUNCATED---') continue ;;
    esac
    IFS=$'\t' read -r tp tt tc <<< "$row"
    [[ -z "${tp:-}" || -z "${tt:-}" ]] && continue
    [[ ! "$tt" =~ ^[RFSPHM]$ ]] && continue
    if [[ "$tp" != "." && ! "$tp" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
      continue
    fi
    if [[ "$tp" == "." ]]; then
      parent=""
    elif [[ "$tp" == */* ]]; then
      parent="${tp%/*}"
    else
      parent=""
    fi
    TREE_PATH+=("$tp")
    TREE_TYPE+=("$tt")
    TREE_CHILDREN+=("${tc:-0}")
    TREE_PARENT+=("$parent")
  done <<< "$body"
  # Apply the same H/M synthesis + nested-Suite demotion as the initial parse.
  post_classify_tree
}

# ---- picker_loop(path) ----
# Recursive drill loop. Communicates with the dispatcher via globals
# PICKER_RESULT ("" or "attach"), PICKER_PROJECT (basename), PICKER_PARENT
# (parent path or "" for root).
#
# Why globals not return codes: under `set -euo pipefail` (line 5), a non-zero
# return from a bare function call aborts the script before any `case "$?"`
# could read it. Globals sidestep the errexit gate without disabling it.
PICKER_RESULT=
PICKER_PROJECT=
PICKER_PARENT=

picker_loop() {
  local path=$1
  while :; do
    build_rows_for_path "$path"
    pick_one
    case "$SELECTED_KIND" in
      back)
        return 0 ;;
      cancel)
        return 0 ;;
      folder)
        # Drill into a Folder OR Suite (both have kind=folder in the picker
        # rows). Recursive — the inner loop returns when the user backs out.
        picker_loop "$SELECTED_PAYLOAD"
        [[ "${PICKER_RESULT:-}" == "attach" ]] && return 0
        ;;
      project)
        # SELECTED_PAYLOAD is the full path; split into parent + basename.
        local full="$SELECTED_PAYLOAD"
        if [[ "$full" == */* ]]; then
          PICKER_PARENT="${full%/*}"
        else
          PICKER_PARENT=""
        fi
        PICKER_PROJECT="${full##*/}"
        PICKER_RESULT=attach
        return 0 ;;
      new_anything)
        prompt_new_anything "$path"
        if (( ${PROMPT_OK:-0} )); then
          if [[ "$PROMPT_KIND" == "attach" ]]; then
            # Project / Hub / Member: attach to tmux on the new entry.
            PICKER_PARENT="$PROMPT_PARENT"
            PICKER_PROJECT="$PROMPT_NAME"
            PICKER_RESULT=attach
            return 0
          fi
          # Folder / Suite: tree was refetched; loop re-renders this level.
        fi
        ;;
    esac
  done
}

# ---- top-level dispatch ----
picker_loop ""
[[ "${PICKER_RESULT:-}" == "attach" ]] || exit 0

PROJECT="$PICKER_PROJECT"
ATTACH_PATH="$PICKER_PARENT"

# Defense-in-depth: revalidate the basename and the parent path against the
# same allowlists we apply to env vars. The basename can only contain the
# characters from the allowlist (the picker enforces that), but defense in
# depth is cheap.
if [[ ! "$PROJECT" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: project directory '${PROJECT}' has characters that cannot be safely passed to SSH." >&2
  echo "  Rename it on ${HOST} to use only letters, digits, '.', '_', '-'." >&2
  exit 1
fi
if [[ -n "$ATTACH_PATH" && ! "$ATTACH_PATH" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: parent path '${ATTACH_PATH}' has characters that cannot be safely passed to SSH." >&2
  exit 1
fi

# ---- attach (or create) tmux session, launch claude, keep shell on exit ----
# Session name is `claudehome-<basename>` regardless of folder depth — the
# folder is invisible at the tmux layer (AC-FT3, spec "Project naming").
#
# `-A` means: attach if exists, create otherwise. We deliberately omit `-D`
# so multiple clients can stay attached to the same session simultaneously.
#
# `mkdir -p` is idempotent: a no-op for existing projects, and creates the
# directory (and any missing parent folders) for newly-named ones.
if (( LOCAL_MODE )); then
  mkdir -p "${LOCAL_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}"
  exec tmux new-session -A -s "claudehome-${PROJECT}" -c "${LOCAL_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}" "claude; exec $SHELL"
else
  # shellcheck disable=SC2029
  exec ssh -t "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
    mkdir -p ${PROJECTS_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}
    tmux new-session -A -s claudehome-${PROJECT} -c ${PROJECTS_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT} \"claude; exec \$SHELL\"
  '"
fi
