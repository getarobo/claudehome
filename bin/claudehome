#!/usr/bin/env bash
# claudehome — connect to a persistent Claude Code session on your Mac mini.
# See README.md for architecture and acceptance criteria.

set -euo pipefail

# ---- help ----
if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  cat <<'USAGE'
Usage: claudehome

  Lists project directories under CLAUDEHOME_PROJECTS_DIR on the Mac mini,
  shows tmux session state for each, and attaches via SSH over Tailscale.
  Sessions are named claudehome-<project> and outlive any claude process.

  When run on the Mac mini itself (auto-detected by hostname, or forced
  with CLAUDEHOME_LOCAL=1), the SSH layer is skipped and the picker plus
  attach run locally — useful when SSH'd into the mini from iPhone, etc.

  Folders organize projects in a drill-down picker — pick [new folder here]
  to create one. Project names are globally unique across the whole tree;
  tmux sessions are named claudehome-<basename> regardless of folder depth.
  The last picker row is [new project here] — pick it to create a fresh
  project at the current drill level. Names are validated against the same
  allowlist applied to env vars; duplicates are refused.

Environment variables (or set in ~/.claudehomerc):
  CLAUDEHOME_HOST          Tailscale hostname of the Mac mini   (required)
  CLAUDEHOME_USER          SSH user on the Mac mini             (default: $USER)
  CLAUDEHOME_PROJECTS_DIR  Projects root on the Mac mini        (default: ~/projects/claudehome-projects)
  CLAUDEHOME_LOCAL         Force local mode (1) or remote (0)   (default: auto-detect)

Config file: ~/.claudehomerc — written by install_client.sh. Format: KEY=VALUE, one per line.
Environment variables take precedence over values in the config file.

Detach from an attached session with tmux's standard binding:
  Ctrl-b then d  (two keystrokes: hold Ctrl+b, release, then press d)
The tmux session keeps running on the Mac mini after you disconnect.

Note: CLAUDEHOME_PROJECTS_DIR is a path on the Mac mini. If you use a
leading ~, set it with single quotes so your client shell does not
expand the tilde locally: export CLAUDEHOME_PROJECTS_DIR='~/other/root'
USAGE
  exit 0
fi

# ---- load config file (env vars take precedence) ----
RC="${HOME}/.claudehomerc"
if [[ -f "$RC" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^(CLAUDEHOME_[A-Z_]+)=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      val="${BASH_REMATCH[2]}"
      if ! printenv "$key" >/dev/null 2>&1; then
        export "$key"="$val"
      fi
    fi
  done < "$RC"
fi

# ---- config ----
HOST="${CLAUDEHOME_HOST:-}"
REMOTE_USER="${CLAUDEHOME_USER:-$USER}"
PROJECTS_DIR="${CLAUDEHOME_PROJECTS_DIR:-~/projects/claudehome-projects}"

if [[ -z "$HOST" ]]; then
  echo "claudehome: CLAUDEHOME_HOST is not set." >&2
  echo "  Run ./install_client.sh to configure, or: export CLAUDEHOME_HOST=<tailscale-hostname>" >&2
  exit 1
fi

# ---- validate config ----
# These values are interpolated into a remote `bash -c '...'` command. Strict
# allowlists close the shell-injection vector (a single quote in any of these
# would break out of the remote bash -c context).
if [[ ! "$HOST" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_HOST='${HOST}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '-'" >&2
  exit 1
fi
if [[ ! "$REMOTE_USER" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_USER='${REMOTE_USER}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '-'" >&2
  exit 1
fi
if [[ ! "$PROJECTS_DIR" =~ ^[a-zA-Z0-9._~/-]+$ ]]; then
  echo "claudehome: CLAUDEHOME_PROJECTS_DIR='${PROJECTS_DIR}' has unsupported characters." >&2
  echo "  Allowed: letters, digits, '.', '_', '/', '~', '-'" >&2
  exit 1
fi

# ---- detect local execution ----
# When CLAUDEHOME_HOST resolves to this machine, skip the SSH hop and run the
# picker + attach locally. Common case: SSH'd into the mini from an iPhone
# (Termius/Blink) — we want the same picker UX, no loopback SSH.
#
# Detection layers:
#   1. CLAUDEHOME_LOCAL=1|true|yes  → force local
#   2. CLAUDEHOME_LOCAL=0|false|no  → force remote (loopback test path)
#   3. Cheap string match: localhost / 127.* / ::1 / hostname forms.
#   4. IP-based match: resolve HOST and compare to local interface IPs. This
#      catches every macOS hostname variant (LocalHostName vs HostName vs
#      Tailscale node name) — they all resolve to the same IPs the box owns.
_resolve_ips() {
  local h=$1
  if command -v dscacheutil >/dev/null 2>&1; then
    dscacheutil -q host -a name "$h" 2>/dev/null \
      | awk '/^ip[46]?_address:/ {print $2}'
  elif command -v getent >/dev/null 2>&1; then
    getent ahosts "$h" 2>/dev/null | awk '{print $1}' | sort -u
  elif command -v host >/dev/null 2>&1; then
    host "$h" 2>/dev/null | awk '/has address|has IPv6 address/ {print $NF}'
  fi
}
_local_ips() {
  if command -v ifconfig >/dev/null 2>&1; then
    ifconfig 2>/dev/null | awk '/^[[:space:]]*inet6? / {print $2}' | sed 's/%.*//'
  elif command -v ip >/dev/null 2>&1; then
    ip -o addr show 2>/dev/null | awk '{print $4}' | sed 's|/.*||'
  fi
}
is_local_target() {
  case "${CLAUDEHOME_LOCAL:-}" in
    1|true|yes) return 0 ;;
    0|false|no) return 1 ;;
  esac
  local target=$1 lc_target lc_full lc_short
  case "$target" in
    localhost|127.*|::1) return 0 ;;
  esac
  lc_target=$(printf '%s' "$target" | tr '[:upper:]' '[:lower:]')
  lc_full=$(hostname 2>/dev/null  | tr '[:upper:]' '[:lower:]')
  lc_short=$(hostname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')
  [[ -n "$lc_full"  && "$lc_target" == "$lc_full"  ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "$lc_short" ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "${lc_short}.local" ]] && return 0
  [[ -n "$lc_short" && "$lc_target" == "${lc_short}".*.ts.net ]] && return 0
  # Final layer: IP intersection between resolved-target and local interfaces.
  local target_ips local_ips tip lip
  target_ips=$(_resolve_ips "$target")
  [[ -z "$target_ips" ]] && return 1
  local_ips=$(_local_ips)
  [[ -z "$local_ips" ]] && return 1
  for tip in $target_ips; do
    for lip in $local_ips; do
      [[ "$tip" == "$lip" ]] && return 0
    done
  done
  return 1
}
LOCAL_MODE=0
is_local_target "$HOST" && LOCAL_MODE=1

# Local mode passes paths to local commands directly, so we expand a leading
# `~/` to $HOME up front. Remote mode leaves PROJECTS_DIR literal — the
# remote bash -c context expands `~` itself.
LOCAL_DIR="$PROJECTS_DIR"
# shellcheck disable=SC2088 # The '~' here is a literal pattern in `case`, not a tilde to expand.
case "$PROJECTS_DIR" in
  '~')   LOCAL_DIR="$HOME" ;;
  '~/'*) LOCAL_DIR="${HOME}/${PROJECTS_DIR#\~/}" ;;
esac

# ---- tree-walk emitter (shared between local and remote modes) ----
# Emits "<path>\t<type>\t<child_count>\n" rows for every directory under the
# projects root, plus optional ---TRUNCATED--- / ---DEPTH-TRUNCATED--- sentinels.
# Type is R (synthetic root, only the `.` row), F (folder — every immediate
# child is a directory), or P (project — empty or has at least one non-dir
# immediate child). See plan §3.1, §3.2.
#
# Quoting: this snippet is interpolated into both the local-mode block (as
# direct shell code) and into the remote `bash --norc --noprofile -c '...'`
# wrapper (where every `$` that should reach the remote bash is escaped to
# `\$` and every double quote is escaped to `\"`). We keep two copies because
# the remote-mode escape conventions diverge enough that a single string with
# placeholder substitution would be more error-prone than two readable copies.

if (( LOCAL_MODE )); then
  RAW=$(
    {
      echo ---TREE---
      ( cd "$LOCAL_DIR" 2>/dev/null && {
          total=$(find . -maxdepth 8 -type d ! -path '*/.*' 2>/dev/null | wc -l | tr -d ' ')
          deeper=$(find . -mindepth 9 -type d ! -path '*/.*' 2>/dev/null | head -n 1)
          # Truncation: macOS BWK awk does not support -v RS='\0' (records get
          # collapsed). We instead count inside the bash while-loop and break
          # at 2000 — portable across BWK awk, GNU awk, and bash 3.2.
          i=0
          find . -maxdepth 8 -type d ! -path '*/.*' -print0 2>/dev/null \
            | while IFS= read -r -d '' p; do
                i=$(( i + 1 ))
                [ "$i" -gt 2000 ] && break
                rel="${p#./}"
                [ "$p" = "." ] && rel="."
                n_all=0; n_dirs=0
                for c in "$p"/* "$p"/.[!.]* "$p"/..?* ; do
                  [ -e "$c" ] || continue
                  n_all=$(( n_all + 1 ))
                  [ -d "$c" ] && n_dirs=$(( n_dirs + 1 ))
                done
                if [ "$rel" = "." ]; then
                  t=R
                elif [ "$n_all" -gt 0 ] && [ "$n_all" = "$n_dirs" ]; then
                  t=F
                else
                  t=P
                fi
                printf '%s\t%s\t%s\n' "$rel" "$t" "$n_all"
              done
          [ "$total" -gt 2000 ] && echo ---TRUNCATED---
          [ -n "$deeper" ] && echo ---DEPTH-TRUNCATED---
        } )
      echo ---TMUX---
      tmux list-sessions -F "#{session_name} #{session_activity}" 2>/dev/null || true
    }
  )
else
  # shellcheck disable=SC2029
  if ! RAW=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
    cd ${PROJECTS_DIR} 2>/dev/null || exit 0
    echo ---TREE---
    total=\$(find . -maxdepth 8 -type d ! -path \"*/.*\" 2>/dev/null | wc -l | tr -d \" \")
    deeper=\$(find . -mindepth 9 -type d ! -path \"*/.*\" 2>/dev/null | head -n 1)
    i=0
    find . -maxdepth 8 -type d ! -path \"*/.*\" -print0 2>/dev/null \
      | while IFS= read -r -d \"\" p; do
          i=\$(( i + 1 ))
          [ \"\$i\" -gt 2000 ] && break
          rel=\"\${p#./}\"
          [ \"\$p\" = \".\" ] && rel=\".\"
          n_all=0; n_dirs=0
          for c in \"\$p\"/* \"\$p\"/.[!.]* \"\$p\"/..?* ; do
            [ -e \"\$c\" ] || continue
            n_all=\$(( n_all + 1 ))
            [ -d \"\$c\" ] && n_dirs=\$(( n_dirs + 1 ))
          done
          if [ \"\$rel\" = \".\" ]; then
            t=R
          elif [ \"\$n_all\" -gt 0 ] && [ \"\$n_all\" = \"\$n_dirs\" ]; then
            t=F
          else
            t=P
          fi
          printf \"%s\\t%s\\t%s\\n\" \"\$rel\" \"\$t\" \"\$n_all\"
        done
    [ \"\$total\" -gt 2000 ] && echo ---TRUNCATED---
    [ -n \"\$deeper\" ] && echo ---DEPTH-TRUNCATED---
    echo ---TMUX---
    tmux list-sessions -F \"#{session_name} #{session_activity}\" 2>/dev/null || true
  '" 2>/dev/null); then
    echo "claudehome: cannot reach ${REMOTE_USER}@${HOST} over SSH." >&2
    echo "  - Check Tailscale is up on both devices:   tailscale status" >&2
    echo "  - Check Mac mini Remote Login is enabled:  System Settings → General → Sharing" >&2
    echo "  - Check your SSH key is authorized on the Mac mini." >&2
    exit 1
  fi
fi

# Split RAW into tree and tmux blocks. The pre-`---TREE---` slice (banner /
# stray output) is discarded.
TREE_BLOCK="${RAW#*---TREE---}"
TREE_BLOCK="${TREE_BLOCK%%---TMUX---*}"
TMUX_BLOCK="${RAW#*---TMUX---}"

# ---- parse tree rows ----
# Populates four parallel arrays keyed by row index:
#   TREE_PATH[i]      — relative path (e.g. "work/client-a/site"; "." for synthetic root)
#   TREE_TYPE[i]      — "R", "F", or "P"
#   TREE_CHILDREN[i]  — immediate-child count (integer)
#   TREE_PARENT[i]    — parent path ("" for top-level rows; "" for "." root)
#
# Wire-format invariant: every emitted path matches
# `^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$` OR is exactly `.`. Rows that fail are
# silently dropped; a single deduped stderr warning is printed per session.
TREE_PATH=()
TREE_TYPE=()
TREE_CHILDREN=()
TREE_PARENT=()
TRUNCATED_ROWS=0
TRUNCATED_DEPTH=0
SKIPPED_BAD_PATHS=0

NOW=$(date +%s)

while IFS= read -r row; do
  [[ -z "$row" ]] && continue
  case "$row" in
    '---TRUNCATED---')      TRUNCATED_ROWS=1;  continue ;;
    '---DEPTH-TRUNCATED---') TRUNCATED_DEPTH=1; continue ;;
  esac
  # TAB-split into three fields.
  IFS=$'\t' read -r tp tt tc <<< "$row"
  [[ -z "${tp:-}" || -z "${tt:-}" ]] && continue
  # Enforce wire-format invariant. A TAB or newline embedded in an on-disk
  # directory name corrupts the wire format mid-row: the first segment lands
  # in $tp (and may pass the allowlist regex), but the type field $tt then
  # holds garbage. Reject any row whose type is not R/F/P, which catches the
  # TAB-in-name case the path allowlist misses.
  if [[ ! "$tt" =~ ^[RFP]$ ]]; then
    SKIPPED_BAD_PATHS=$(( SKIPPED_BAD_PATHS + 1 ))
    continue
  fi
  if [[ "$tp" != "." && ! "$tp" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
    SKIPPED_BAD_PATHS=$(( SKIPPED_BAD_PATHS + 1 ))
    continue
  fi
  # Compute parent.
  if [[ "$tp" == "." ]]; then
    parent=""
  elif [[ "$tp" == */* ]]; then
    parent="${tp%/*}"
  else
    parent=""
  fi
  TREE_PATH+=("$tp")
  TREE_TYPE+=("$tt")
  TREE_CHILDREN+=("${tc:-0}")
  TREE_PARENT+=("$parent")
done <<< "$TREE_BLOCK"

if (( SKIPPED_BAD_PATHS > 0 )); then
  echo "claudehome: skipped ${SKIPPED_BAD_PATHS} path with disallowed characters — rename on the mini to surface it" >&2
fi
if (( TRUNCATED_ROWS )); then
  echo "claudehome: tree truncated at 2000 entries — clean up your projects dir" >&2
fi
if (( TRUNCATED_DEPTH )); then
  echo "claudehome: tree depth >8 not shown — reorganize on the mini" >&2
fi

# ---- helpers shared by drill loop ----

# Look up tmux session activity for a basename. Sets ACT_TS (timestamp string,
# empty if idle) and ACT_LABEL (human "5m ago" string, empty if idle).
_session_activity() {
  local basename=$1
  ACT_TS=$(awk -v s="claudehome-${basename}" '$1==s { print $2; exit }' <<< "$TMUX_BLOCK")
  ACT_LABEL=
  if [[ -n "${ACT_TS:-}" ]]; then
    local age=$(( NOW - ACT_TS ))
    (( age < 0 )) && age=0   # clamp client-vs-server clock skew
    if   (( age < 60 ));    then ACT_LABEL="${age}s ago"
    elif (( age < 3600 ));  then ACT_LABEL="$(( age / 60 ))m ago"
    elif (( age < 86400 )); then ACT_LABEL="$(( age / 3600 ))h ago"
    else                         ACT_LABEL="$(( age / 86400 ))d ago"
    fi
  fi
}

# ---- build_rows_for_path(path) ----
# Filters TREE_* arrays to direct children of $path and populates three
# parallel arrays of picker rows:
#   PICKER_LINES[]    — display strings (what fzf/select see)
#   PICKER_KIND[]     — one of: back / folder / project / root_bucket / new_folder / new_project
#   PICKER_PAYLOAD[]  — context-dependent: full path for folder/project, ".root" for root_bucket, "" for the rest
#
# Special case: path == ".root" filters to root-level projects only (the
# synthetic `(root)` drill).
build_rows_for_path() {
  local path=$1
  PICKER_LINES=()
  PICKER_KIND=()
  PICKER_PAYLOAD=()

  # [..  back] for non-root non-root_bucket frames.
  if [[ -n "$path" && "$path" != ".root" ]]; then
    PICKER_LINES+=("[..  back]")
    PICKER_KIND+=("back")
    PICKER_PAYLOAD+=("")
  fi

  local i n n_rows=${#TREE_PATH[@]}
  local folder_lines=() folder_paths=()
  local active_lines=() active_keys=()
  local idle_lines=() idle_keys=()

  # `path == ".root"` means "list root-level projects only" — a virtual drill
  # into the synthetic root bucket. Translate to the real filter: parent==""
  # AND type==P, skipping any folders.
  local match_parent root_bucket_mode=0
  if [[ "$path" == ".root" ]]; then
    match_parent=""
    root_bucket_mode=1
  else
    match_parent="$path"
  fi

  # Track presence of folders + projects at top level for the `(root)` bucket
  # decision. We only care about this when path == "" (true top level).
  local root_has_folders=0 root_has_projects=0

  for (( i=0; i<n_rows; i++ )); do
    local p="${TREE_PATH[$i]}"
    local t="${TREE_TYPE[$i]}"
    local par="${TREE_PARENT[$i]}"
    # Skip the synthetic root row itself.
    [[ "$p" == "." ]] && continue
    if [[ -z "$path" ]]; then
      [[ "$par" == "" && "$t" == "F" ]] && root_has_folders=1
      [[ "$par" == "" && "$t" == "P" ]] && root_has_projects=1
    fi
    [[ "$par" != "$match_parent" ]] && continue
    if (( root_bucket_mode )); then
      # Root bucket: only show projects, never folders.
      [[ "$t" != "P" ]] && continue
    fi
    local basename="${p##*/}"
    if [[ "$t" == "F" ]]; then
      n="${TREE_CHILDREN[$i]}"
      folder_lines+=("${basename}/  (${n})")
      folder_paths+=("$p")
    else
      _session_activity "$basename"
      if [[ -n "${ACT_TS:-}" ]]; then
        active_lines+=("${basename}  [active ${ACT_LABEL}]")
        active_keys+=("${ACT_TS}"$'\t'"${basename}")
      else
        idle_lines+=("${basename}  [idle]")
        idle_keys+=("${basename}")
      fi
    fi
  done

  # Sort folders alphabetically by basename — emit display lines in basename
  # order. We sort the parallel arrays via a tagged sort.
  if (( ${#folder_lines[@]} > 0 )); then
    local sorted
    sorted=$(
      local k
      for (( k=0; k<${#folder_lines[@]}; k++ )); do
        printf '%s\t%s\n' "${folder_lines[$k]}" "${folder_paths[$k]}"
      done | LC_ALL=C sort
    )
    while IFS=$'\t' read -r fline fpath; do
      [[ -z "$fline" ]] && continue
      PICKER_LINES+=("$fline")
      PICKER_KIND+=("folder")
      PICKER_PAYLOAD+=("$fpath")
    done <<< "$sorted"
  fi

  # Active projects descending by timestamp, then idle alphabetical.
  if (( ${#active_lines[@]} > 0 )); then
    local sorted
    sorted=$(
      local k
      for (( k=0; k<${#active_lines[@]}; k++ )); do
        printf '%s\t%s\n' "${active_keys[$k]}" "${active_lines[$k]}"
      done | LC_ALL=C sort -t$'\t' -k1,1nr -k2,2
    )
    while IFS=$'\t' read -r _ts _name aline; do
      # active_keys is "<ts>\t<basename>", so split is 3 fields total
      [[ -z "${aline:-}" ]] && continue
      # The basename is the last "  " segment of the line; recover it.
      local apname="${aline%%  *}"
      PICKER_LINES+=("$aline")
      PICKER_KIND+=("project")
      PICKER_PAYLOAD+=("${match_parent:+$match_parent/}$apname")
    done <<< "$sorted"
  fi
  if (( ${#idle_lines[@]} > 0 )); then
    local sorted
    sorted=$(printf '%s\n' "${idle_lines[@]}" | LC_ALL=C sort)
    while IFS= read -r iline; do
      [[ -z "$iline" ]] && continue
      local ipname="${iline%%  *}"
      PICKER_LINES+=("$iline")
      PICKER_KIND+=("project")
      PICKER_PAYLOAD+=("${match_parent:+$match_parent/}$ipname")
    done <<< "$sorted"
  fi

  # `(root)` bucket — only at true top level (path == "") and only when both
  # root folders AND root projects exist.
  if [[ -z "$path" ]] && (( root_has_folders )) && (( root_has_projects )); then
    # Count root projects for the (N) annotation.
    local root_n=0
    for (( i=0; i<n_rows; i++ )); do
      [[ "${TREE_TYPE[$i]}" == "P" && "${TREE_PARENT[$i]}" == "" ]] && root_n=$(( root_n + 1 ))
    done
    PICKER_LINES+=("(root)  (${root_n})")
    PICKER_KIND+=("root_bucket")
    PICKER_PAYLOAD+=(".root")
    # When the (root) bucket is shown, the per-project root rows we already
    # appended above are duplicates — strip them. We do that by rebuilding
    # the arrays minus the project rows we just added at top level. This
    # only applies at the true top level.
    local kept_lines=() kept_kinds=() kept_pls=()
    for (( i=0; i<${#PICKER_LINES[@]}; i++ )); do
      if [[ "${PICKER_KIND[$i]}" == "project" && "${PICKER_PAYLOAD[$i]}" != */* ]]; then
        continue
      fi
      kept_lines+=("${PICKER_LINES[$i]}")
      kept_kinds+=("${PICKER_KIND[$i]}")
      kept_pls+=("${PICKER_PAYLOAD[$i]}")
    done
    PICKER_LINES=("${kept_lines[@]}")
    PICKER_KIND=("${kept_kinds[@]}")
    PICKER_PAYLOAD=("${kept_pls[@]}")
  fi

  PICKER_LINES+=("[new folder here]")
  PICKER_KIND+=("new_folder")
  PICKER_PAYLOAD+=("")
  PICKER_LINES+=("[new project here]")
  PICKER_KIND+=("new_project")
  PICKER_PAYLOAD+=("")
}

# ---- pick_one ----
# Renders PICKER_LINES via fzf (preferred) or bash select (fallback).
# Sets globals SELECTED_KIND and SELECTED_PAYLOAD by looking up the picked
# line's index in PICKER_LINES. Sets SELECTED_KIND=cancel on Ctrl-D / empty.
pick_one() {
  SELECTED_KIND=
  SELECTED_PAYLOAD=
  local picked=
  if command -v fzf >/dev/null 2>&1; then
    if ! picked=$(printf '%s\n' "${PICKER_LINES[@]}" | fzf --prompt='claudehome> ' --height=~50% --reverse); then
      SELECTED_KIND=cancel
      return 0
    fi
  else
    local PS3='Select: '
    select picked in "${PICKER_LINES[@]}"; do
      [[ -n "${picked:-}" ]] && break
    done
    if [[ -z "${picked:-}" ]]; then
      SELECTED_KIND=cancel
      return 0
    fi
  fi
  # Look up the index by line.
  local i
  for (( i=0; i<${#PICKER_LINES[@]}; i++ )); do
    if [[ "${PICKER_LINES[$i]}" == "$picked" ]]; then
      SELECTED_KIND="${PICKER_KIND[$i]}"
      SELECTED_PAYLOAD="${PICKER_PAYLOAD[$i]}"
      return 0
    fi
  done
  # No match (shouldn't happen) — treat as cancel.
  SELECTED_KIND=cancel
}

# ---- creation flows ----
# Both prompt_new_folder and prompt_new_project read a basename from stdin,
# enforce the standard allowlist, and check for collisions. They communicate
# success via globals (PROMPT_NAME for both; the picker_loop assigns it into
# PICKER_PROJECT for the new_project case). Returning non-zero would clash
# with `set -euo pipefail`; instead they set PROMPT_OK to 1 (success) or 0.

# prompt_new_folder $parent_path
# On success: creates the folder on disk, re-fetches and re-parses the tree,
# and sets PROMPT_OK=1. On failure: sets PROMPT_OK=0 and re-prompts handled
# by the caller.
prompt_new_folder() {
  local parent=$1
  local name=
  PROMPT_OK=0
  PROMPT_NAME=
  while :; do
    if ! read -r -p "New folder name: " name; then
      return 0
    fi
    [[ -z "$name" ]] && return 0
    if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+$ ]]; then
      echo "  '${name}' has unsupported characters. Allowed: letters, digits, '.', '_', '-'. Try again." >&2
      continue
    fi
    # Reject `.`, `..`, and leading-dot names. The allowlist regex permits
    # them character-wise, but `..` would create the folder above the projects
    # root, and leading-dot names are filtered by the tree walk so they
    # disappear from the picker on next launch.
    if [[ "$name" == "." || "$name" == ".." || "$name" == .* ]]; then
      echo "  '${name}' is reserved. Pick a different name." >&2
      continue
    fi
    # Sibling collision: any row at the same parent with the same basename,
    # regardless of type (folder OR project).
    local i collide=0
    for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
      [[ "${TREE_PARENT[$i]}" != "$parent" ]] && continue
      local ex_basename="${TREE_PATH[$i]##*/}"
      if [[ "$ex_basename" == "$name" ]]; then
        collide=1
        break
      fi
    done
    if (( collide )); then
      local where="${parent:+$parent/}${name}"
      echo "  '${name}' already exists at ${where}. Pick a different name." >&2
      continue
    fi
    # Create on disk.
    local rel="${parent:+$parent/}${name}"
    if (( LOCAL_MODE )); then
      mkdir -p "${LOCAL_DIR}/${rel}"
    else
      # shellcheck disable=SC2029
      ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
        "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c 'mkdir -p ${PROJECTS_DIR}/${rel}'" >/dev/null 2>&1 || true
    fi
    # Re-fetch and re-parse the tree so the new folder is visible in the
    # next picker render.
    refetch_tree
    PROMPT_NAME="$name"
    PROMPT_OK=1
    return 0
  done
}

# prompt_new_project $parent_path
# On success: sets PROMPT_OK=1 and PROMPT_NAME=<basename>. The caller wires
# the rest of the attach machinery; mkdir for the project happens at attach
# time (existing behavior — see L302+ attach branch).
prompt_new_project() {
  local parent=$1
  local name=
  PROMPT_OK=0
  PROMPT_NAME=
  while :; do
    if ! read -r -p "New project name: " name; then
      return 0
    fi
    [[ -z "$name" ]] && return 0
    if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+$ ]]; then
      echo "  '${name}' has unsupported characters. Allowed: letters, digits, '.', '_', '-'. Try again." >&2
      continue
    fi
    if [[ "$name" == "." || "$name" == ".." || "$name" == .* ]]; then
      echo "  '${name}' is reserved. Pick a different name." >&2
      continue
    fi
    # Sibling collision (same parent, any type).
    local i collide=0
    for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
      [[ "${TREE_PARENT[$i]}" != "$parent" ]] && continue
      local ex_basename="${TREE_PATH[$i]##*/}"
      if [[ "$ex_basename" == "$name" ]]; then
        collide=1
        break
      fi
    done
    if (( collide )); then
      local where="${parent:+$parent/}${name}"
      echo "  '${name}' already exists at ${where}. Pick a different name." >&2
      continue
    fi
    # Globally-unique scan: any P-type row anywhere in the tree with the
    # same basename. Cite the conflicting full path.
    local conflict=
    for (( i=0; i<${#TREE_PATH[@]}; i++ )); do
      [[ "${TREE_TYPE[$i]}" != "P" ]] && continue
      local ex_basename="${TREE_PATH[$i]##*/}"
      if [[ "$ex_basename" == "$name" ]]; then
        conflict="${TREE_PATH[$i]}"
        break
      fi
    done
    if [[ -n "$conflict" ]]; then
      echo "  '${name}' already exists at ${conflict}. Pick a different name." >&2
      continue
    fi
    PROMPT_NAME="$name"
    PROMPT_OK=1
    return 0
  done
}

# refetch_tree
# Re-runs the tree-walk emitter and re-parses TREE_* arrays. Used after a
# folder creation so the new folder is visible in the next picker render.
# Performance note: a re-fetch is one local find or one SSH round-trip; the
# user already paid for one tree walk on startup, so a second one after
# folder creation is acceptable.
refetch_tree() {
  local fresh
  if (( LOCAL_MODE )); then
    fresh=$(
      {
        echo ---TREE---
        ( cd "$LOCAL_DIR" 2>/dev/null && {
            total=$(find . -maxdepth 8 -type d ! -path '*/.*' 2>/dev/null | wc -l | tr -d ' ')
            deeper=$(find . -mindepth 9 -type d ! -path '*/.*' 2>/dev/null | head -n 1)
            i=0
            find . -maxdepth 8 -type d ! -path '*/.*' -print0 2>/dev/null \
              | while IFS= read -r -d '' p; do
                  i=$(( i + 1 ))
                  [ "$i" -gt 2000 ] && break
                  rel="${p#./}"
                  [ "$p" = "." ] && rel="."
                  n_all=0; n_dirs=0
                  for c in "$p"/* "$p"/.[!.]* "$p"/..?* ; do
                    [ -e "$c" ] || continue
                    n_all=$(( n_all + 1 ))
                    [ -d "$c" ] && n_dirs=$(( n_dirs + 1 ))
                  done
                  if [ "$rel" = "." ]; then
                    t=R
                  elif [ "$n_all" -gt 0 ] && [ "$n_all" = "$n_dirs" ]; then
                    t=F
                  else
                    t=P
                  fi
                  printf '%s\t%s\t%s\n' "$rel" "$t" "$n_all"
                done
            [ "$total" -gt 2000 ] && echo ---TRUNCATED---
            [ -n "$deeper" ] && echo ---DEPTH-TRUNCATED---
          } )
        echo ---TMUX---
        tmux list-sessions -F "#{session_name} #{session_activity}" 2>/dev/null || true
      }
    )
  else
    # shellcheck disable=SC2029
    fresh=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
      cd ${PROJECTS_DIR} 2>/dev/null || exit 0
      echo ---TREE---
      total=\$(find . -maxdepth 8 -type d ! -path \"*/.*\" 2>/dev/null | wc -l | tr -d \" \")
      deeper=\$(find . -mindepth 9 -type d ! -path \"*/.*\" 2>/dev/null | head -n 1)
      i=0
      find . -maxdepth 8 -type d ! -path \"*/.*\" -print0 2>/dev/null \
        | while IFS= read -r -d \"\" p; do
            i=\$(( i + 1 ))
            [ \"\$i\" -gt 2000 ] && break
            rel=\"\${p#./}\"
            [ \"\$p\" = \".\" ] && rel=\".\"
            n_all=0; n_dirs=0
            for c in \"\$p\"/* \"\$p\"/.[!.]* \"\$p\"/..?* ; do
              [ -e \"\$c\" ] || continue
              n_all=\$(( n_all + 1 ))
              [ -d \"\$c\" ] && n_dirs=\$(( n_dirs + 1 ))
            done
            if [ \"\$rel\" = \".\" ]; then
              t=R
            elif [ \"\$n_all\" -gt 0 ] && [ \"\$n_all\" = \"\$n_dirs\" ]; then
              t=F
            else
              t=P
            fi
            printf \"%s\\t%s\\t%s\\n\" \"\$rel\" \"\$t\" \"\$n_all\"
          done
      [ \"\$total\" -gt 2000 ] && echo ---TRUNCATED---
      [ -n \"\$deeper\" ] && echo ---DEPTH-TRUNCATED---
      echo ---TMUX---
      tmux list-sessions -F \"#{session_name} #{session_activity}\" 2>/dev/null || true
    '" 2>/dev/null) || {
      echo "claudehome: tree refresh failed; using cached view" >&2
      return 0
    }
  fi
  # Re-parse into TREE_* arrays.
  local body="${fresh#*---TREE---}"
  body="${body%%---TMUX---*}"
  TMUX_BLOCK="${fresh#*---TMUX---}"
  TREE_PATH=()
  TREE_TYPE=()
  TREE_CHILDREN=()
  TREE_PARENT=()
  while IFS= read -r row; do
    [[ -z "$row" ]] && continue
    case "$row" in
      '---TRUNCATED---'|'---DEPTH-TRUNCATED---') continue ;;
    esac
    IFS=$'\t' read -r tp tt tc <<< "$row"
    [[ -z "${tp:-}" || -z "${tt:-}" ]] && continue
    [[ ! "$tt" =~ ^[RFP]$ ]] && continue
    if [[ "$tp" != "." && ! "$tp" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
      continue
    fi
    if [[ "$tp" == "." ]]; then
      parent=""
    elif [[ "$tp" == */* ]]; then
      parent="${tp%/*}"
    else
      parent=""
    fi
    TREE_PATH+=("$tp")
    TREE_TYPE+=("$tt")
    TREE_CHILDREN+=("${tc:-0}")
    TREE_PARENT+=("$parent")
  done <<< "$body"
}

# ---- picker_loop(path) ----
# Recursive drill loop. Communicates with the dispatcher via globals
# PICKER_RESULT ("" or "attach"), PICKER_PROJECT (basename), PICKER_PARENT
# (parent path or "" for root).
#
# Why globals not return codes: under `set -euo pipefail` (line 5), a non-zero
# return from a bare function call aborts the script before any `case "$?"`
# could read it. Globals sidestep the errexit gate without disabling it.
PICKER_RESULT=
PICKER_PROJECT=
PICKER_PARENT=

picker_loop() {
  local path=$1
  while :; do
    build_rows_for_path "$path"
    pick_one
    case "$SELECTED_KIND" in
      back)
        return 0 ;;
      cancel)
        return 0 ;;
      folder)
        picker_loop "$SELECTED_PAYLOAD"
        [[ "${PICKER_RESULT:-}" == "attach" ]] && return 0
        ;;
      root_bucket)
        picker_loop ".root"
        [[ "${PICKER_RESULT:-}" == "attach" ]] && return 0
        ;;
      project)
        # SELECTED_PAYLOAD is the full path; split into parent + basename.
        local full="$SELECTED_PAYLOAD"
        if [[ "$full" == */* ]]; then
          PICKER_PARENT="${full%/*}"
        else
          PICKER_PARENT=""
        fi
        PICKER_PROJECT="${full##*/}"
        PICKER_RESULT=attach
        return 0 ;;
      new_folder)
        prompt_new_folder "$path"
        # Stay at this level; the next loop iteration re-renders with the
        # new folder visible (or unchanged on validation failure).
        ;;
      new_project)
        prompt_new_project "$path"
        if (( ${PROMPT_OK:-0} )); then
          # `path == ".root"` means "root projects view" — the actual parent
          # for a project created here is "" (true root), not ".root".
          if [[ "$path" == ".root" ]]; then
            PICKER_PARENT=""
          else
            PICKER_PARENT="$path"
          fi
          PICKER_PROJECT="$PROMPT_NAME"
          PICKER_RESULT=attach
          return 0
        fi
        ;;
    esac
  done
}

# ---- top-level dispatch ----
picker_loop ""
[[ "${PICKER_RESULT:-}" == "attach" ]] || exit 0

PROJECT="$PICKER_PROJECT"
ATTACH_PATH="$PICKER_PARENT"

# Defense-in-depth: revalidate the basename and the parent path against the
# same allowlists we apply to env vars. The basename can only contain the
# characters from the allowlist (the picker enforces that), but defense in
# depth is cheap.
if [[ ! "$PROJECT" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: project directory '${PROJECT}' has characters that cannot be safely passed to SSH." >&2
  echo "  Rename it on ${HOST} to use only letters, digits, '.', '_', '-'." >&2
  exit 1
fi
if [[ -n "$ATTACH_PATH" && ! "$ATTACH_PATH" =~ ^([a-zA-Z0-9._-]+/)*[a-zA-Z0-9._-]+$ ]]; then
  echo "claudehome: parent path '${ATTACH_PATH}' has characters that cannot be safely passed to SSH." >&2
  exit 1
fi

# ---- attach (or create) tmux session, launch claude, keep shell on exit ----
# Session name is `claudehome-<basename>` regardless of folder depth — the
# folder is invisible at the tmux layer (AC-FT3, spec "Project naming").
#
# `-A` means: attach if exists, create otherwise. We deliberately omit `-D`
# so multiple clients can stay attached to the same session simultaneously.
#
# `mkdir -p` is idempotent: a no-op for existing projects, and creates the
# directory (and any missing parent folders) for newly-named ones.
if (( LOCAL_MODE )); then
  mkdir -p "${LOCAL_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}"
  exec tmux new-session -A -s "claudehome-${PROJECT}" -c "${LOCAL_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}" "claude; exec $SHELL"
else
  # shellcheck disable=SC2029
  exec ssh -t "${REMOTE_USER}@${HOST}" "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash --norc --noprofile -c '
    mkdir -p ${PROJECTS_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT}
    tmux new-session -A -s claudehome-${PROJECT} -c ${PROJECTS_DIR}/${ATTACH_PATH:+$ATTACH_PATH/}${PROJECT} \"claude; exec \$SHELL\"
  '"
fi
